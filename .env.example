# Notion API key — get it from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your_key_here

# Root page name — must match your Notion template's top-level page title (default: "Max Brain")
# ROOT_PAGE_NAME=Max Brain

# Databases sub-page name (default: "Databases")
# DATABASES_PAGE_NAME=Databases

# Database IDs — OPTIONAL, auto-discovered from your root page structure.
# Only set these if auto-discovery fails or you have duplicate database names.
# MAX_BRAIN_PAGE_ID=your_page_id
# PROJECTS_DB_ID=your_projects_database_id
# TASKS_DB_ID=your_tasks_database_id
# NOTES_DB_ID=your_notes_database_id
# AREAS_DB_ID=your_areas_database_id
# GOALS_DB_ID=your_goals_database_id

# Property name overrides — OPTIONAL, only if you renamed properties in Notion.
# Format: PROP_{DB}_{PROPERTY}=ActualName
# Example: PROP_TASKS_DUE=Deadline
