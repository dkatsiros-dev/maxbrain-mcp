{
  "name": "@dkatsiros/notion-brain",
  "version": "1.0.0",
  "description": "MCP server connecting Claude Code, Gemini CLI, and other MCP clients to your Notion second brain (PARA method)",
  "type": "module",
  "bin": {
    "notion-brain": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/**/*.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "notion",
    "claude",
    "ai",
    "second-brain",
    "para",
    "productivity"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@notionhq/client": "^2.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
